@model ActividadAutonoma.Models.PokemonDetail

@{
    ViewData["Title"] = Model.Name;
    string GetTypeColor(string type)
    {
        var typeColors = new Dictionary<string, string>
        {
            {"normal", "#A8A878"}, {"fire", "#F08030"}, {"water", "#6890F0"},
            {"electric", "#F8D030"}, {"grass", "#78C850"}, {"ice", "#98D8D8"},
            {"fighting", "#C03028"}, {"poison", "#A040A0"}, {"ground", "#E0C068"},
            {"flying", "#A890F0"}, {"psychic", "#F85888"}, {"bug", "#A8B820"},
            {"rock", "#B8A038"}, {"ghost", "#705898"}, {"dragon", "#7038F8"},
            {"dark", "#705848"}, {"steel", "#B8B8D0"}, {"fairy", "#EE99AC"}
        };
        return typeColors.ContainsKey(type) ? typeColors[type] : "#68A090";
    }
}

<div class="container py-4">
    <div class="text-center mb-4">
        <h1 class="text-capitalize fw-bold display-4 neon-title">@Model.Name</h1>
        <p class="text-muted">#@Model.Id.ToString("000")</p>
    </div>

    <div class="row justify-content-center">

        <!-- INFO IZQUIERDA -->
        <div class="col-md-7">
            <div class="card custom-card h-100">
                <div class="card-body p-4 text-light">

                    <!-- TIPOS -->
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">Tipo</h5>
                        <div class="d-flex gap-2">
                            @foreach (var t in Model.Types)
                            {
                                <span class="badge type-badge text-capitalize"
                                      style="background-color: @GetTypeColor(t.Type.Name);">
                                    @t.Type.Name
                                </span>
                            }
                        </div>
                    </div>

                    <!-- ALTURA Y PESO -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="info-box">
                                <p>Altura</p>
                                <h5>@(Model.Height / 10.0)m</h5>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box">
                                <p>Peso</p>
                                <h5>@(Model.Weight / 10.0)kg</h5>
                            </div>
                        </div>
                    </div>

                    <!-- ESTADISTICAS CIRCULARES -->
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">Estadísticas</h5>

                        <div class="stats-grid">
                            @foreach (var s in Model.Stats)
                            {
                                var percentage = Math.Min(s.Base_Stat, 150) / 150.0 * 100;

                                <div class="circle-stat">
                                    <svg viewBox="0 0 36 36">
                                        <path class="bg"
                                              d="M18 2 a 16 16 0 0 1 0 32 a 16 16 0 0 1 0 -32" />
                                        <path class="progress"
                                              stroke-dasharray="@percentage, 100"
                                              d="M18 2 a 16 16 0 0 1 0 32 a 16 16 0 0 1 0 -32" />
                                    </svg>

                                    <div class="circle-text">
                                        <strong>@s.Base_Stat</strong>
                                        <span>@s.Stat.Name</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- HABILIDADES -->
                    @if (Model.Abilities != null && Model.Abilities.Count > 0)
                    {
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Habilidades</h5>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var a in Model.Abilities)
                                {
                                    <span class="ability-badge">@a.Ability.Name</span>
                                }
                            </div>
                        </div>
                    }

                    <div class="text-center mt-4">
                        <a href="@Url.Action("Index", "Poke")" class="btn neon-btn">
                            Volver a la lista
                        </a>
                    </div>

                </div>
            </div>
        </div>

        <!-- IMAGEN DERECHA -->
        <div class="col-md-5 mb-4">
            <div class="card custom-card">
                <div class="card-body p-4 text-center">

                    <img src="@Model.Sprites?.Front_Default"
                         class="img-fluid pokemon-main-img mb-3"
                         id="mainPokemonImage" />

                    <h5 class="mb-3 text-light">Sprites</h5>

                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        @if (!string.IsNullOrEmpty(Model.Sprites?.Front_Default))
                        {
                            <img src="@Model.Sprites.Front_Default" class="pokemon-thumb"
                                 onclick="changeImage('@Model.Sprites.Front_Default')" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Sprites?.Back_Default))
                        {
                            <img src="@Model.Sprites.Back_Default" class="pokemon-thumb"
                                 onclick="changeImage('@Model.Sprites.Back_Default')" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Sprites?.Front_Shiny))
                        {
                            <img src="@Model.Sprites.Front_Shiny" class="pokemon-thumb"
                                 onclick="changeImage('@Model.Sprites.Front_Shiny')" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Sprites?.Back_Shiny))
                        {
                            <img src="@Model.Sprites.Back_Shiny" class="pokemon-thumb"
                                 onclick="changeImage('@Model.Sprites.Back_Shiny')" />
                        }
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function changeImage(src) {
            document.getElementById('mainPokemonImage').src = src;
        }
    </script>
}

<style>
    body {
        background: #0f172a;
    }

    /* título */
    .neon-title {
        color: #38bdf8;
    }

    /* card */
    .custom-card {
        background: #1e293b;
        border-radius: 20px;
        border: 1px solid #334155;
    }

    /* imagen */
    .pokemon-main-img {
        height: 250px;
    }

    /* miniaturas */
    .pokemon-thumb {
        width: 50px;
        cursor: pointer;
    }

    /* tipo */
    .type-badge {
        color: white;
        padding: 8px 14px;
        border-radius: 12px;
    }

    /* info */
    .info-box {
        background: #020617;
        padding: 15px;
        border-radius: 10px;
        text-align: center;
    }

    /* stats grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 20px;
    }

    /* circulo */
    .circle-stat {
        position: relative;
        width: 100px;
        height: 100px;
        margin: auto;
    }

        .circle-stat svg {
            transform: rotate(-90deg);
        }

        .circle-stat path {
            fill: none;
            stroke-width: 3;
        }

        .circle-stat .bg {
            stroke: #334155;
        }

        .circle-stat .progress {
            stroke: #38bdf8;
            stroke-linecap: round;
        }

    .circle-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        font-size: 12px;
    }

    /* habilidades */
    .ability-badge {
        background: #334155;
        padding: 6px 12px;
        border-radius: 10px;
    }

    /* botón */
    .neon-btn {
        background: #0ea5e9;
        color: white;
    }
</style>